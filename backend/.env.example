# Copy this file to ".env" and fill in your key.

# Anthropic API key (Claude Sonnet)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Model to use. Claude Sonnet is a good lightweight/fast choice.
# Change this to whichever Sonnet snapshot your account has access to.
ANTHROPIC_MODEL=claude-sonnet-4-6

# Temperature for the agent (keep low for deterministic admissions decisions)
AGENT_TEMPERATURE=0

# CORS origin for the React dev server
FRONTEND_ORIGIN=http://localhost:5173

# How many future academic years the agent should treat as valid intakes
INTAKE_YEARS_AHEAD=2
